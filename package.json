{
  "name": "@aneuhold/main-scripts",
  "author": "Anton G. Neuhold Jr.",
  "license": "MIT",
  "version": "2.8.2",
  "description": "Main scripts for use personally on any platform",
  "packageManager": "pnpm@10.20.0",
  "type": "module",
  "scripts": {
    "refresh": "pnpm build && npm uninstall -g @aneuhold/main-scripts && npm i -g",
    "watch": "nodemon --ignore lib/ --ignore localData/ -e ts --exec \"pnpm build:without-rimraf && npm uninstall -g @aneuhold/main-scripts && npm i -g\"",
    "build": "rimraf lib && pnpm build:without-rimraf",
    "build:without-rimraf": "tsc --project tsconfig.build.json && shx cp package.json lib/package.json",
    "lint": "eslint",
    "test": "vitest run",
    "upgrade:core": "pnpm update '@aneuhold/*' --latest",
    "upgrade:all": "pnpm update --latest",
    "reset:global": "npm uninstall -g @aneuhold/main-scripts && npm i -g @aneuhold/main-scripts"
  },
  "main": "lib/index.js",
  "module": "lib/index.js",
  "bin": {
    "tb": "lib/index.js"
  },
  "files": [
    "lib/**/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aneuhold/main-scripts.git"
  },
  "bugs": {
    "url": "https://github.com/aneuhold/main-scripts/issues"
  },
  "homepage": "https://github.com/aneuhold/main-scripts#readme",
  "keywords": [
    "Scripting",
    "Node.js"
  ],
  "dependencies": {
    "@aneuhold/core-ts-lib": "^2.3.18",
    "@inquirer/prompts": "^8.2.1",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "fs-extra": "^11.3.3",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@aneuhold/eslint-config": "^2.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.3",
    "@types/node-fetch": "^2.6.13",
    "eslint": "^10.0.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "shx": "^0.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
